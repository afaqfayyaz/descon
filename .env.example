# ---- Application ----
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-in-production
# Auth.js v5 reads AUTH_SECRET (keep it identical to NEXTAUTH_SECRET)
AUTH_SECRET=change-me-in-production
AUTH_TRUST_HOST=true

# ---- Database ----
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=caliber

# ---- Authentication (Azure AD / Microsoft Entra ID SSO — optional) ----
# When CLIENT_ID and CLIENT_SECRET are set, a "Sign in with Microsoft" button
# appears on the login page. Only employees already provisioned in the users
# collection (matched by email) are allowed in.
# Register an app at https://entra.microsoft.com and add this redirect URI:
#   {NEXTAUTH_URL}/api/auth/callback/microsoft-entra-id
# Leave TENANT_ID empty to use the multi-tenant "common" endpoint.
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ---- Email (SMTP) ----
# For local development, run `docker compose up mailpit` and use:
#   SMTP_HOST=localhost  SMTP_PORT=1025  (web UI: http://localhost:8025)
# Leave SMTP_HOST empty to disable email entirely (in-app notifications still work).
SMTP_HOST=smtp.caliber.app
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Caliber <noreply@caliber.app>"

# ---- Notifications ----
# Shared secret for the deadline-reminder cron endpoint.
# Call: POST /api/cron/reminders with header "Authorization: Bearer <CRON_SECRET>"
# Leave empty to disable the endpoint (returns 503).
CRON_SECRET=

# ---- Optional ----
SENTRY_DSN=
LOG_LEVEL=info
